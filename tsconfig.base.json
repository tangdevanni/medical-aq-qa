{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@medical-ai-qa/finale-workbook-intake": ["services/finale-workbook-intake/src"],
      "@medical-ai-qa/shared-config": ["packages/shared-config/src"],
      "@medical-ai-qa/shared-logging": ["packages/shared-logging/src"],
      "@medical-ai-qa/shared-types": ["packages/shared-types/src"]
    }
  }
}
