{
  "name": "@medical-ai-qa/dashboard",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "clean": "node ./scripts/clean-dashboard.mjs",
    "dev": "node ./scripts/dev-dashboard.mjs",
    "create-qa-user": "node ./scripts/create-qa-user.mjs",
    "build": "next build",
    "rebuild": "pnpm run clean && next build",
