NEXT_PUBLIC_API_BASE_URL=http://localhost:3000
DASHBOARD_SESSION_SECRET=replace-with-at-least-32-random-characters
DASHBOARD_SESSION_TTL_HOURS=12
DASHBOARD_ALLOW_PLAINTEXT_PASSWORDS=false
DASHBOARD_QA_USERS_JSON=[{"email":"qa@example.com","name":"QA User","passwordHash":"sha256:replace-with-dashboard-qa-user-script-output","allowedAgencyIds":["aplus-home-health","active-home-health","avery-home-health","meadows-home-health","star-home-health"]}]

