FINALE_BATCH_OUTPUT_DIR=./artifacts/finale-batch
FINALE_LOG_LEVEL=info
PORTAL_BASE_URL=https://app.finalehealth.com
PORTAL_USERNAME=
PORTAL_PASSWORD=
PORTAL_AUTH_STATE_PATH=./.auth/portal-state.json
PORTAL_HEADLESS=true
PORTAL_WORKBOOK_DOWNLOAD_TIMEOUT_MS=30000
PORTAL_WORKBOOK_MIN_BYTES=1024
PORTAL_TRACE_ON_FAILURE=true
OASIS_WRITE_ENABLED=false
CODE_LLM_ENABLED=false
LLM_PROVIDER=bedrock
BEDROCK_REGION=us-east-1
BEDROCK_MODEL_ID=amazon.nova-lite-v1:0
# Optional explicit override for models that require inference profiles.
# Example: BEDROCK_INFERENCE_PROFILE_ID=us.amazon.nova-lite-v1:0
BEDROCK_INFERENCE_PROFILE_ID=
TEXTRACT_S3_BUCKET=
TEXTRACT_S3_REGION=us-east-2
TEXTRACT_S3_PREFIX=finale-workbook-intake/textract
TEXTRACT_POLL_INTERVAL_MS=2000
TEXTRACT_JOB_TIMEOUT_MS=120000
# IAM required for Converse API:
# - bedrock:InvokeModel
# - bedrock:InvokeModelWithResponseStream (only if streaming is enabled in future)
# IAM required for OCR fallback:
# - textract:DetectDocumentText
# - textract:StartDocumentTextDetection
# - textract:GetDocumentTextDetection
# - s3:PutObject
# - s3:GetObject
